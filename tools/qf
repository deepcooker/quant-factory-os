def tail_lines(path: str, n: int) -> list[str]:
    if not os.path.exists(path):
        return []
    with open(path, "r", encoding="utf-8") as f:
        lines = f.readlines()
    return [x.rstrip("\n") for x in lines[-n:]]

def read_ready(path: str) -> dict:
    if not os.path.exists(path):
