        "dependencies": ["SYNC/discussion/", "reports/<RUN_ID>/"],
        "scope_hint": ["tools/qf", "docs/WORKFLOW.md", "AGENTS.md", "SYNC/"],
        "score": score_for(76, ["discussion", "report", "confirm", "evidence", "orient"]),
