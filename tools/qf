        explicit_run_id="${arg#RUN_ID=}"
        ;;
      ANSWER_FILE=*)
        answer_file="${arg#ANSWER_FILE=}"
        ;;
      RUBRIC_FILE=*)
        rubric_file="${arg#RUBRIC_FILE=}"
        ;;
      OUTPUT_FILE=*)
        output_file="${arg#OUTPUT_FILE=}"
        ;;
      AUTO_FILL=*)
        auto_fill="${arg#AUTO_FILL=}"
