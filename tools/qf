  local project_id=""
  local token=""
  local orient_file=""
  local orient_md=""
  local task_file=""
  local current_status=""

  for token in "$@"; do
    [[ -z "$token" ]] && continue
    case "$token" in
      RUN_ID=*)
        explicit_run_id="${token#RUN_ID=}"
        ;;
      PROJECT_ID=*)
        explicit_project_id="${token#PROJECT_ID=}"
        ;;
      *)
        if [[ -z "$explicit_run_id" ]]; then
          explicit_run_id="$token"
        fi
        ;;
    esac
  done
  if [[ -z "$explicit_run_id" && -n "${RUN_ID:-}" ]]; then
    explicit_run_id="${RUN_ID}"
  fi

