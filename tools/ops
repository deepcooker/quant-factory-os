#!/usr/bin/env python3
from __future__ import annotations

import os
import shutil
import sys
from pathlib import Path


ROOT_DIR = Path(__file__).resolve().parents[1]
LEGACY = ROOT_DIR / "tools" / "ops_legacy.sh"
# Passthrough contract: delegated commands consume env vars such as RUN_ID/PROJECT_ID.

PYTHON_FIRST_COMMANDS = {
    "init": "ops_init.py",
    "learn": "ops_learn.py",
    "ready": "ops_ready.py",
    "orient": "ops_orient.py",
    "choose": "ops_choose.py",
    "council": "ops_council.py",
    "arbiter": "ops_arbiter.py",
    "slice": "ops_slice.py",
}


def eprint(msg: str) -> None:
    print(msg, file=sys.stderr)


def pick_python() -> str:
    if sys.executable:
        return sys.executable
    py3 = shutil.which("python3")
    if py3:
        return py3
    py = shutil.which("python")
    return py or ""


def execv(cmd: list[str]) -> None:
    os.execvpe(cmd[0], cmd, os.environ.copy())


def run_legacy(argv: list[str]) -> int:
    if not LEGACY.is_file():
        eprint("ERROR: missing script: tools/ops_legacy.sh")
        return 1
    execv([str(LEGACY), *argv])
    return 0


def run_python(script_name: str, argv: list[str]) -> int:
    py_bin = pick_python()
    if not py_bin:
        eprint(f"ERROR: python is required to run {script_name}")
        return 1
    script = ROOT_DIR / "tools" / script_name
    if not script.is_file():
        eprint(f"ERROR: missing script: tools/{script_name}")
        return 1
    execv([py_bin, str(script), *argv])
    return 0


def main(argv: list[str]) -> int:
    subcmd = argv[0] if argv else ""
    if subcmd in {"", "-h", "--help", "help"}:
        return run_legacy(argv)
    script_name = PYTHON_FIRST_COMMANDS.get(subcmd)
    if script_name:
        return run_python(script_name, argv[1:])
    return run_legacy(argv)


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
