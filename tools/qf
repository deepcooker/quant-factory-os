        "cost": "S",
        "dependencies": ["TASKS/STATE.md", "reports/<RUN_ID>/ship_state.json"],
        "scope_hint": ["tools/qf", "tests/"],
        "score": score_for(82, ["ready", "resume", "stop reason", "run", "state"]),
