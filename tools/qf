  fi
  append_execution_event "$run_id" "exam" "exam_graded" "$status" "tools/qf exam RUN_ID=${run_id}" "answer=${answer_file};rubric=${rubric_file};output=${output_file}" "$output"
  if [[ "$rc" -ne 0 ]]; then
    exit "$rc"
  fi
}

