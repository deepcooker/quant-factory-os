resolve_ready_field() {
  local env_key="$1"
  local prompt="$2"
  local default_value="${3:-}"
  local auto_mode="${QF_READY_AUTO:-1}"
  local value="${!env_key:-}"
  if [[ -n "$value" ]]; then
    printf "%s" "$value"
    return 0
  fi
  if [[ "$auto_mode" == "1" && -n "$default_value" ]]; then
    printf "%s" "$default_value"
    return 0
  fi
  if [[ -t 0 ]]; then
    echo -n "$prompt"
    IFS= read -r value
    printf "%s" "$value"
    return 0
  fi
  echo "ERROR: missing $env_key and no interactive stdin for prompt: $prompt" >&2
  return 1
}

