#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
LEGACY="$ROOT_DIR/tools/qf_legacy.sh"
# Passthrough contract: delegated commands consume env vars such as RUN_ID/PROJECT_ID.

pick_python() {
  if command -v python3 >/dev/null 2>&1; then
    echo "python3"
  elif command -v python >/dev/null 2>&1; then
    echo "python"
  else
    echo ""
  fi
}

run_python_cmd() {
  local script="$1"
  shift
  local py_bin
  py_bin="$(pick_python)"
  if [[ -z "$py_bin" ]]; then
    echo "ERROR: python is required to run $script" >&2
    return 1
  fi
  if [[ ! -f "$ROOT_DIR/tools/$script" ]]; then
    echo "ERROR: missing script: tools/$script" >&2
    return 1
  fi
  exec "$py_bin" "$ROOT_DIR/tools/$script" "$@"
}

subcmd="${1:-}"
case "$subcmd" in
  ""|-h|--help|help)
    exec "$LEGACY" "$@"
    ;;
  init)
    shift
    run_python_cmd qf_init.py "$@"
    ;;
  learn)
    shift
    run_python_cmd qf_learn.py "$@"
    ;;
  ready)
    shift
    run_python_cmd qf_ready.py "$@"
    ;;
  orient)
    shift
    run_python_cmd qf_orient.py "$@"
    ;;
  choose)
    shift
    run_python_cmd qf_choose.py "$@"
    ;;
  council)
    shift
    run_python_cmd qf_council.py "$@"
    ;;
  arbiter)
    shift
    run_python_cmd qf_arbiter.py "$@"
    ;;
  slice)
    shift
    run_python_cmd qf_slice.py "$@"
    ;;
  *)
    exec "$LEGACY" "$@"
    ;;
esac
